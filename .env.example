# Cinechrony — environment variables
#
# Copy to `.env.local` for local dev, and set the same in the Vercel project
# (Settings -> Environment Variables) for prod/preview. `NEXT_PUBLIC_*` vars are
# inlined into the client bundle at BUILD time, so after changing one you MUST
# redeploy for it to take effect. Values here are placeholders — never commit
# real secrets (this file is a template; .env.local is gitignored).

# ── Firebase (client SDK — public) ─────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (server — SECRET) ───────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Used by the username-login path (Identity Toolkit REST). Same value as the
# NEXT_PUBLIC one; kept server-side too.
FIREBASE_API_KEY=

# ── TMDB / OMDB (movie data) ───────────────────────────────────────────────
NEXT_PUBLIC_TMDB_ACCESS_TOKEN=   # client-direct search (public read token)
TMDB_ACCESS_TOKEN=               # server proxies (trending, details)
OMDB_API_KEY=                    # supplementary IMDb ratings (server)

# ── Cloudflare R2 (image storage — SECRET) ─────────────────────────────────
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# ── Web push (VAPID) ───────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Phase C extraction: Gemini + Apify ─────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FALLBACKS=          # optional comma-list of fallback models
APIFY_TOKEN=
APIFY_ACTOR_ID=                  # TikTok/multi-platform downloader
APIFY_ACTOR_INSTAGRAM=           # IG reels downloader (has a built-in fallback)
EXTRACTION_CONFIDENCE_MIN=0.45   # optional; drop candidates below this

# ── Transactional email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=cinechrony <noreply@cinechrony.com>
RESEND_REPLY_TO=

# ── Observability: Sentry (errors) ─────────────────────────────────────────
# All Sentry/PostHog code is a no-op until these are set.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=                      # optional; falls back to the NEXT_PUBLIC one
NEXT_PUBLIC_SENTRY_ENV=          # optional label (e.g. production)
SENTRY_ENV=

# ── Analytics: PostHog (product) ───────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=         # the "Project token" (phc_...), NOT a Personal API key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── App origin / API routing ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=             # the single prod origin (CORS + OG absolute urls)
NEXT_PUBLIC_API_BASE_URL=        # Capacitor static build points here (cross-origin API)
NEXT_PUBLIC_PREVIEW_API_TARGET=  # optional; preview routes API calls to prod

# ── Admin / cron ───────────────────────────────────────────────────────────
ADMIN_SECRET=                    # gates /api/v1/admin/* (constant-time compare)
CRON_SECRET=                     # gates the weekly-digest cron route

# ── Misc / tuning ──────────────────────────────────────────────────────────
DISABLE_SERVER_CACHE=            # set to 1 to bypass in-process TTL caches (debug)
