{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 9002",
    "build": "NODE_ENV=production next build",
    "build:static": "NODE_ENV=production bash scripts/static-build.sh",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "audit:test": "JAVA_HOME=/opt/homebrew/opt/openjdk@21 PATH=/opt/homebrew/opt/openjdk@21/bin:$PATH firebase emulators:exec --only firestore,auth --project demo-cinechrony 'node --experimental-test-module-mocks --import tsx --import ./scripts/audit-tests/setup.ts --test --test-concurrency=1 scripts/audit-tests/*.test.ts'",
    "cap:sync": "npm run build:static && cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "npm run build:static && cap sync ios && cap run ios",
    "cap:run:android": "npm run build:static && cap sync android && cap run android",
    "cap:assets": "capacitor-assets generate --iconBackgroundColor '#f7f3eb' --iconBackgroundColorDark '#0a0a0a' --splashBackgroundColor '#f7f3eb' --splashBackgroundColorDark '#0a0a0a'"
  },
