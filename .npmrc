# Capacitor Firebase plugins (@capacitor-firebase/*) declare a peer dependency
# on a newer firebase major (^12.x) than this app runs (firebase 11.x). The
# web-SDK APIs we use (signInWithCredential, getMessaging, etc.) are stable
# across that boundary, so we pin to 11.x and tell npm to use the lenient
# (npm-v6-style) peer resolution — otherwise a fresh `npm install` (Vercel,
# CI, a clean clone) aborts with ERESOLVE. Without this file the install only
# works on machines that already have node_modules populated.
#
# When firebase is deliberately upgraded to 12.x (a tested, standalone task),
# this flag can likely be removed.
legacy-peer-deps=true
